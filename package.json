{
  "name": "hlym-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "security:scan": "npm audit --audit-level=high",
    "supabase:start": "supabase start -x vector,logflare",
    "supabase:start:full": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:diff": "supabase db diff",
    "supabase:db:push": "supabase db push",
    "supabase:assets:sync": "node scripts/sync-supabase-assets.mjs",
    "webflow:library:bundle": "webflow library bundle --public-path /public --output-path .webflow/library-dist --no-input --skip-update-check",
    "webflow:library:share": "webflow library share --skip-update-check",
    "webflow:devlink:sync": "webflow devlink sync --skip-update-check"
  },
  "dependencies": {
    "@fontsource/lato": "^5.2.7",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.468.0",
    "mapbox-gl": "^3.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@webflow/data-types": "^1.2.1",
    "@webflow/react": "^1.2.1",
    "@webflow/styled-components-utils": "^1.2.1",
    "@webflow/webflow-cli": "^1.21.0",
    "ajv": "^8.18.0",
    "babel-plugin-styled-components": "^2.1.4",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "koa": "3.2.0"
  }
}
